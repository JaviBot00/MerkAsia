<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
                             http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
<!--    FindClientDNI  -->
    <servlet>
        <servlet-name>FindClientDNI</servlet-name>
        <servlet-class>com.politecnicomalaga.merkasia.view.FindClientDNI</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FindClientDNI</servlet-name>
        <url-pattern>/find-cliente</url-pattern>
    </servlet-mapping>

<!--    FindProductCode-->
    <servlet>
        <servlet-name>FindProductCode</servlet-name>
        <servlet-class>com.politecnicomalaga.merkasia.view.FindProductCode</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>FindProductCode</servlet-name>
        <url-pattern>/find-producto</url-pattern>
    </servlet-mapping>

<!--    ImportData-->
    <servlet>
        <servlet-name>ImportData</servlet-name>
        <servlet-class>com.politecnicomalaga.merkasia.view.ImportData</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ImportData</servlet-name>
        <url-pattern>/import-data</url-pattern>
    </servlet-mapping>

<!--    ListProducts-->
    <servlet>
        <servlet-name>ListProducts</servlet-name>
        <servlet-class>com.politecnicomalaga.merkasia.view.ListProducts</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListProducts</servlet-name>
        <url-pattern>/list-productos</url-pattern>
    </servlet-mapping>

<!--    ListProductsOrder-->
    <servlet>
        <servlet-name>ListProductsOrder</servlet-name>
        <servlet-class>com.politecnicomalaga.merkasia.view.ListProductsOrder</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ListProductsOrder</servlet-name>
        <url-pattern>/list-producto-pedido</url-pattern>
    </servlet-mapping>
</web-app>
